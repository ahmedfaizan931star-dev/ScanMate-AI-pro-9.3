<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ScanMate.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F1117</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenIconBackgroundColor">#0F1117</item>
        <item name="postSplashScreenTheme">@style/Theme.ScanMate</item>
    </style>

    <style name="Theme.ScanMate" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:colorAccent">#4B8EF8</item>
    </style>
</resources>
