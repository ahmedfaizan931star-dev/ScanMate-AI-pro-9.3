+    private fun excelColumnName(index: Int): String {
+        var value = index
+        val result = StringBuilder()
+        while (value > 0) {
+            val rem = (value - 1) % 26
+            result.insert(0, ('A'.code + rem).toChar())
+            value = (value - 1) / 26
+        }
+        return result.toString()
+    }
